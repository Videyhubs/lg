generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// === CORE MODELS ===

model Link {
  id            String   @id @default(cuid())
  slug          String   @unique
  originalUrl   String
  customSlug    String?
  title         String?
  password      String?
  expiresAt     DateTime?
  maxClicks     Int?
  geoTarget     String?   // JSON: {"US": "url1", "ID": "url2"}
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  clicks        Click[]
}

model Article {
  id            String   @id @default(cuid())
  slug          String   @unique
  title         String
  content       String   @default("")
  excerpt       String?
  thumbnail     String?
  category      String?
  tags          String?   // JSON array
  author        String   @default("Admin")
  readTime      Int      @default(5)
  trendingScore Int      @default(0)
  fakeViews     Int      @default(0)
  isPublished   Boolean  @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Click {
  id            String   @id @default(cuid())
  linkId        String
  link          Link     @relation(fields: [linkId], references: [id], onDelete: Cascade)
  
  ip            String?
  country       String?
  device        String?
  browser       String?
  os            String?
  referer       String?
  isBot         Boolean  @default(false)
  createdAt     DateTime  @default(now())
}

// === SETTINGS & CONFIG ===

model SiteSetting {
  id            String   @id @default(cuid())
  key           String   @unique
  value         String
  updatedAt     DateTime  @updatedAt
}

model AdSlot {
  id            String   @id @default(cuid())
  name          String
  position      String   // banner_top, banner_middle, banner_bottom, native, sticky, floating, in_article, popunder
  scriptHtml    String?
  isEnabled     Boolean  @default(true)
  deviceTarget  String?  // all, mobile, desktop
  frequencyCap  Int?     // max impressions per session
  priority      Int      @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model AdminAccount {
  id            String   @id @default(cuid())
  username      String   @unique
  passwordHash  String
  role          String   @default("admin")
  lastLogin     DateTime?
  loginAttempts Int      @default(0)
  lockedUntil   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model BlacklistIp {
  id            String   @id @default(cuid())
  ip            String   @unique
  reason        String?
  createdAt     DateTime  @default(now())
}

model VisitorSession {
  id            String   @id @default(cuid())
  sessionId     String
  ip            String?
  country       String?
  device        String?
  browser       String?
  path          String?
  createdAt     DateTime  @default(now())
}
